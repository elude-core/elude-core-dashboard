# === Upstream data sources (Docker network privé sur VM elude-core) ===
KUMA_API_URL=http://elude-core-uptime-kuma:3001
KUMA_API_KEY=

PROMETHEUS_URL=http://elude-core-prometheus:9090

N8N_API_URL=http://elude-core-n8n:5678
N8N_API_KEY=

# Hetzner Cloud read-only token (pour /dashboard/infra)
HETZNER_API_TOKEN=

# === Cache ===
REDIS_URL=redis://elude-core-redis:6379/2

# === Events timeline (elude-sync /events public endpoint) ===
NEXT_PUBLIC_EVENTS_URL=https://sync.elude.fr/events

# === Observability (Sentry) ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# === Build info ===
NEXT_PUBLIC_DASHBOARD_VERSION=0.2.0-dev
